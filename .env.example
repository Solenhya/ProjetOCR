# ==========================
# Database configuration
# ==========================
DBUSER=postgres
DBPASSWORD=postgres
DBHOST=localhost
DBNAME=ocr_db
DBPORT=5432

# Optional schema name (used in parts of the app/documentation)
DB_SCHEMA=public

# ==========================
# JWT / Authentication
# ==========================
# Replace with a strong secret in production
SECRET_KEY=change-me-with-a-strong-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================
# External invoice list service
# ==========================
# Host only, without protocol (the code already prefixes with https://)
# Example: myaccount.blob.core.windows.net
LIST_HOST=example.blob.core.windows.net

# Query string signature/token for remote list/image requests
# Example: sv=...&ss=...&srt=...&sp=...&se=...&st=...&spr=https&sig=...
LIST_AUTH=sv=example&sig=example
